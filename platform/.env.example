# ============================================================
# Cafe OS — environment (copy to .env and fill in)
# ============================================================

# --- Postgres -----------------------------------------------
# LOCAL DEV (default): real Postgres run from `npm run db:local` (no Docker/install).
# Leave these as-is and you're ready to go locally.
DATABASE_URL="postgresql://cafeos:cafeos@localhost:5433/cafeos"
DIRECT_URL="postgresql://cafeos:cafeos@localhost:5433/cafeos"

# PUSH TO CLOUD (later): comment out the two lines above and use Neon/Supabase.
# Nothing else changes — same schema, same code.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/cafeos?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/cafeos?sslmode=require"

# --- Redis (Upstash) ----------------------------------------
REDIS_URL="rediss://default:PASSWORD@HOST:6379"

# --- Auth ----------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"
# Customer OTP login (Phase 2). The dev-scaffold sender logs the code to the
# server console; set OTP_DEV_ECHO=1 to also return the code in the API response
# (handy for staging without an SMS provider). Auto-on outside production.
OTP_DEV_ECHO="0"

# --- Multi-tenancy (Phase G) --------------------------------
# Production resolves the tenant from the request host (kaava.chayaone.com →
# Tenant.subdomain "kaava"). Local dev has no subdomains, so set this to the
# seeded tenant's subdomain so public/PWA routes and PIN login resolve a tenant.
# Also set it on a SINGLE-TENANT production deploy whose host carries no tenant
# subdomain (e.g. a *.up.railway.app URL) so the PWA/PIN-login resolve a tenant.
# (resolveTable also auto-falls back to the sole tenant when only one exists.)
DEV_TENANT_SUBDOMAIN="kahwa"
# Super-admin session secret (separate from staff JWT_SECRET) — used from G4.
PLATFORM_JWT_SECRET="change-me-to-another-long-random-string"

# --- Razorpay (payments) ------------------------------------
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="xxxxxxxx"

# --- Pusher (realtime: KDS, order status, rooms) ------------
PUSHER_APP_ID="xxxxxx"
PUSHER_KEY="xxxxxx"
PUSHER_SECRET="xxxxxx"
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY="xxxxxx"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# --- AI (Phase 3 assistants) --------------------------------
GEMINI_API_KEY="AIzaSy-xxxx"

# --- WhatsApp Cloud API (Phase 2 campaigns) -----------------
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
