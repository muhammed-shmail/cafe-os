{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run db:generate && npm run build"
  },
  "deploy": {
    "startCommand": "npm run -w @cafeos/web start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
