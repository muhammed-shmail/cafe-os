FROM node:20-alpine

WORKDIR /app

# Copy package and config files
COPY platform/package.json .
COPY platform/package-lock.json .
COPY platform/turbo.json .
COPY platform/tsconfig.base.json .

# Copy the entire platform directory structure
COPY platform/apps ./apps
COPY platform/packages ./packages

# Install dependencies
RUN npm ci

# Generate Prisma client and build
RUN npm run db:generate && npm run build

EXPOSE 3000

CMD ["npm", "run", "-w", "@cafeos/web", "start"]
